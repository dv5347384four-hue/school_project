generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  TEACHER
  STUDENT
  PARENT
  REGISTRAR
  GUEST
}

enum AttendanceStatus {
  PRESENT
  LATE
  SICK
  ABSENT
}

enum GradeValueType {
  CURRENT
  TEST
  HOMEWORK
  FINAL
}

model School {
  id        String   @id @default(cuid())
  name      String
  city      String
  createdAt DateTime @default(now())
  users     User[]
  classes   Class[]
}

model User {
  id              String     @id @default(cuid())
  schoolId        String
  email           String     @unique
  passwordHash    String
  firstName       String
  lastName        String
  isEmailVerified Boolean    @default(false)
  role            RoleName
  locale          String     @default("ru")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  school          School     @relation(fields: [schoolId], references: [id])
  student         Student?
  teacher         Teacher?
  parent          Parent?
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]
  notifications   Notification[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Student {
  id            String               @id @default(cuid())
  userId         String               @unique
  classId        String
  admissionDate  DateTime
  user           User                 @relation(fields: [userId], references: [id])
  class          Class                @relation(fields: [classId], references: [id])
  enrollments    Enrollment[]
  grades         Grade[]
  attendance     Attendance[]
  submissions    HomeworkSubmission[]
  parents        ParentStudent[]
}

model Parent {
  id         String          @id @default(cuid())
  userId      String          @unique
  phone       String?
  user        User            @relation(fields: [userId], references: [id])
  children    ParentStudent[]
}

model ParentStudent {
  parentId   String
  studentId  String
  relation   String
  parent     Parent  @relation(fields: [parentId], references: [id])
  student    Student @relation(fields: [studentId], references: [id])

  @@id([parentId, studentId])
}

model Teacher {
  id        String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id])
  subjects   Subject[]
  lessons    Lesson[]
  homework   Homework[]
}

model Class {
  id         String      @id @default(cuid())
  schoolId    String
  name        String
  shift       String
  school      School      @relation(fields: [schoolId], references: [id])
  students    Student[]
  enrollments Enrollment[]
  lessons     Lesson[]
  announcements Announcement[]
}

model Subject {
  id         String       @id @default(cuid())
  schoolId    String
  teacherId   String
  name        String
  school      School       @relation(fields: [schoolId], references: [id])
  teacher     Teacher      @relation(fields: [teacherId], references: [id])
  lessons     Lesson[]
  enrollments Enrollment[]
  gradeTypes  GradeType[]
  grades      Grade[]
  homework    Homework[]
}

model Enrollment {
  id         String   @id @default(cuid())
  classId     String
  subjectId   String
  studentId   String
  class       Class    @relation(fields: [classId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])

  @@unique([subjectId, studentId])
}

model Lesson {
  id         String   @id @default(cuid())
  classId     String
  subjectId   String
  teacherId   String
  weekday     Int
  startsAt    String
  endsAt      String
  blockName   String?
  class       Class    @relation(fields: [classId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  attendance  Attendance[]
}

model GradeType {
  id        String         @id @default(cuid())
  subjectId String
  type      GradeValueType
  weight    Float          @default(1)
  subject   Subject        @relation(fields: [subjectId], references: [id])
  grades    Grade[]
}

model Grade {
  id              String   @id @default(cuid())
  studentId       String
  subjectId       String
  gradeTypeId     String
  value           Float
  reason          String?
  changedByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  student         Student  @relation(fields: [studentId], references: [id])
  subject         Subject  @relation(fields: [subjectId], references: [id])
  gradeType       GradeType @relation(fields: [gradeTypeId], references: [id])
}

model Attendance {
  id        String           @id @default(cuid())
  lessonId  String
  studentId String
  status    AttendanceStatus
  note      String?
  date      DateTime
  lesson    Lesson           @relation(fields: [lessonId], references: [id])
  student   Student          @relation(fields: [studentId], references: [id])
}

model Homework {
  id          String               @id @default(cuid())
  subjectId   String
  teacherId   String
  title       String
  description String
  dueDate     DateTime
  createdAt   DateTime             @default(now())
  subject     Subject              @relation(fields: [subjectId], references: [id])
  teacher     Teacher              @relation(fields: [teacherId], references: [id])
  submissions HomeworkSubmission[]
}

model HomeworkSubmission {
  id          String   @id @default(cuid())
  homeworkId  String
  studentId   String
  status      String
  comment     String?
  submittedAt DateTime?
  homework    Homework @relation(fields: [homeworkId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  senderId    String
  recipientId String
  body        String
  createdAt   DateTime @default(now())
}

model Announcement {
  id         String   @id @default(cuid())
  classId     String?
  title       String
  body        String
  createdAt   DateTime @default(now())
  class       Class?   @relation(fields: [classId], references: [id])
}

model File {
  id         String   @id @default(cuid())
  ownerId    String
  fileName   String
  mimeType   String
  size       Int
  path       String
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  payload   Json
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  metadata  Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Setting {
  id        String @id @default(cuid())
  schoolId  String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([schoolId, key])
}
